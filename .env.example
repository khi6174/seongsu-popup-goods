# 이 파일을 복사해 .env 로 만들고 값을 채우세요.  (cp .env.example .env)

# Supabase(PostgreSQL) 접속 — Supabase 대시보드 > Connect > ORMs > Prisma 에서 복사.
# DATABASE_URL = 트랜잭션 풀러(6543, 앱 런타임) / DIRECT_URL = 세션 풀러(5432, 마이그레이션)
# [YOUR-PASSWORD] 자리에 프로젝트 생성 시 정한 DB 비밀번호를 넣으세요.
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# Anthropic Claude API 키 (AI 챗봇/번역용). https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=""
